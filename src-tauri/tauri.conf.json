{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TimeTracker",
  "version": "0.4.0-alpha",
  "identifier": "com.timetracker.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TimeTracker",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 550,
        "decorations": true,
        "visible": false,
        "backgroundColor": "#0f1117"
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "title": "TimeTracker",
        "width": 340,
        "height": 220,
        "decorations": false,
        "resizable": false,
        "visible": true,
        "center": true,
        "alwaysOnTop": true,
        "shadow": true,
        "backgroundColor": "#0f1117"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
